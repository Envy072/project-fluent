# Project Fluent — root environment variables (development)
# Copy this file to .env.local and fill in real values. Never commit .env or .env.local.
# For a real production deployment, see .env.production.example instead.

NODE_ENV=development

# Distinct from NODE_ENV: NODE_ENV=production is Next.js/Node's own
# runtime-optimization switch (set even when rehearsing the production
# Docker build locally). DEPLOYMENT_ENVIRONMENT is the actual "is this a
# real deployment" signal — only "production" enables the fail-fast
# rejection of known dev/CI placeholder secrets at startup. See
# apps/api/src/config/environment-variables.ts and
# apps/web/lib/environment-variables.ts. One of: local, ci, staging, production.
DEPLOYMENT_ENVIRONMENT=local

# --- API (apps/api) ---
PORT=4000

# The origin allowed to make cross-origin requests to the API (CORS). Should
# match wherever apps/web is served from.
WEB_APP_URL=http://localhost:3100

# Symmetric secret used by the Identity & Access Service (apps/api) to sign
# and verify its own access tokens (@nestjs/jwt). This is entirely separate
# from Auth.js's AUTH_SECRET below — the API never trusts or decodes
# Auth.js's session cookie directly (per ADR-005). Generate with, e.g.:
#   openssl rand -base64 32
AUTH_JWT_SECRET=replace-with-a-long-random-string-in-every-real-environment

# How long an access token issued by /auth/login or /auth/register remains
# valid. Accepts any "zeit/ms"-style duration string (e.g. "1d", "12h").
AUTH_JWT_EXPIRES_IN=1d

# API key for the Anthropic Claude API (ADR-003), used by the AI
# Integration Module (M21) for Topic Generation and Composition Content
# Generation, invoked by the Session Generation Service's GenerateSession
# operation. Required at startup, consistent with this project's fail-fast
# convention for other required secrets.
ANTHROPIC_API_KEY=replace-with-a-real-anthropic-api-key-in-every-real-environment

# Overrides the Claude model used by the AI Integration Module. Optional —
# defaults to a current Claude model if unset.
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- Web (apps/web) ---

# Browser-facing URL of the API, used for any direct client-side calls.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Server-side URL the Next.js server itself uses to reach the API (e.g. from
# Auth.js's `authorize()` callback, which runs on the server, never in the
# browser). In Docker this differs from NEXT_PUBLIC_API_URL — it points at
# the api service's internal Docker network address, not localhost.
API_URL=http://localhost:4000

# Canonical URL of the Next.js app itself. Required by next-auth v4 (the
# stable line — see technology-selection-and-adr.md's rationale for not
# using the long-beta v5/"Auth.js" branding) to construct correct
# callback/redirect URLs.
NEXTAUTH_URL=http://localhost:3100

# Secret Auth.js uses to encrypt the browser's session cookie/JWT. Entirely
# separate from AUTH_JWT_SECRET above (see ADR-005). Generate with, e.g.:
#   openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-different-long-random-string-in-every-real-environment

# --- Infrastructure (Docker development environment) ---
# These match the services defined in docker-compose.yml.
DATABASE_URL=postgresql://fluent:fluent_dev_password@localhost:5432/project_fluent
REDIS_URL=redis://localhost:6379
