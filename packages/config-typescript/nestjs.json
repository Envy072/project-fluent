{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Project Fluent NestJS",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "./dist",
    "declaration": false,
    "declarationMap": false,
    "incremental": false,
    "noEmit": false
  }
}
