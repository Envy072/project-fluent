# Project Fluent — PRODUCTION environment variable reference.
#
# This file documents every environment variable a real production
# deployment requires. It contains no real values, and must never contain
# one — copy the variable names into your actual secret store (GitHub
# Actions encrypted secrets today; AWS Secrets Manager, SSM Parameter
# Store, or Vercel's environment variables dashboard once the production
# cloud account exists) and set real values there instead.
#
# See docs/engineering/production-deployment-guide.md for how these
# variables are validated at startup (M38's Environment Validation stage)
# and how the deployment pipeline uses them.

NODE_ENV=production

# The real, authoritative signal that this is a production deployment.
# When set to "production", the application refuses to start if any
# secret below still matches a known development/CI placeholder pattern
# (see apps/api/src/config/environment-variables.ts and
# apps/web/lib/environment-variables.ts). Never set this to "production"
# outside a real, deliberate production deployment.
DEPLOYMENT_ENVIRONMENT=production

# --- API (apps/api) ---
PORT=4000

# Must be the real production frontend origin — used for CORS.
WEB_APP_URL=REPLACE_WITH_REAL_PRODUCTION_FRONTEND_ORIGIN

# Generate with: openssl rand -base64 32
# Must be a real, unique value — never reused from any lower environment,
# and must not contain "dev-only", "ci-only", "placeholder", or similar.
AUTH_JWT_SECRET=REPLACE_WITH_A_REAL_SECRET_NEVER_COMMITTED
AUTH_JWT_EXPIRES_IN=1d

# Real Anthropic API key (ADR-003). Required for Session Generation to
# function; the application will not start without it.
ANTHROPIC_API_KEY=REPLACE_WITH_A_REAL_ANTHROPIC_API_KEY
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Real production database and cache connection strings. Provisioning the
# actual RDS/ElastiCache instances these point to is deferred to the
# future Infrastructure-as-Code sprint (Terraform) — this file only
# documents the shape the application expects once they exist.
DATABASE_URL=REPLACE_WITH_REAL_PRODUCTION_DATABASE_URL
REDIS_URL=REPLACE_WITH_REAL_PRODUCTION_REDIS_URL

# --- Web (apps/web) ---

# Browser-facing URL of the API. Inlined into the client bundle at BUILD
# time (see apps/web/Dockerfile) — cannot be changed at container runtime.
NEXT_PUBLIC_API_URL=REPLACE_WITH_REAL_PRODUCTION_API_ORIGIN

# Server-side URL the Next.js server itself uses to reach the API.
API_URL=REPLACE_WITH_REAL_PRODUCTION_API_ORIGIN

NEXTAUTH_URL=REPLACE_WITH_REAL_PRODUCTION_FRONTEND_ORIGIN

# Generate with: openssl rand -base64 32
# Must be a different real value from AUTH_JWT_SECRET above (see ADR-005),
# and must not contain any development/CI placeholder marker.
NEXTAUTH_SECRET=REPLACE_WITH_A_DIFFERENT_REAL_SECRET_NEVER_COMMITTED

# --- Observability (ADR-011) ---
# Not yet wired to a real Datadog account (see Sprint 7's completion
# report) — structured JSON logs already ship to stdout, ready for an
# Agent to tail once one is configured. No DATADOG_API_KEY exists yet.
